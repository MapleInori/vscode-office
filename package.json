{
    "name":  "vscode-office-lit",
    "displayName":  "Office Viewer Lit",
    "description":  "Lite Office Viewer: CSV/TSV viewer and WYSIWYG editor for Markdown.",
    "version":  "4.1.0",
    "publisher":  "mapleinori",
    "icon":  "image/logo.png",
    "engines":  {
                    "vscode":  "^1.64.0"
                },
    "keywords":  [
                     "csv",
                     "tsv",
                     "markdown",
                     "toml",
                     "yaml",
                     "xml"
                 ],
    "categories":  [
                       "Visualization",
                       "Other"
                   ],
    "bugs":  {
                 "url":  "https://github.com/MapleInori/vscode-office/issues",
                 "email":  "cweijan@163.com"
             },
    "homepage":  "https://github.com/MapleInori/vscode-office/blob/main/README.md",
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/MapleInori/vscode-office.git"
                   },
    "activationEvents":  [
                             "onCustomEditor:mapleinori.officeViewerLit",
                             "onCustomEditor:mapleinori.markdownViewerLit",
                             "onCommand:office-lit.markdown.switch",
                             "onCommand:office-lit.csv.switch",
                             "onCommand:office-lit.markdown.paste"
                         ],
    "main":  "./out/extension.js",
    "browser":  "./out/extension.web.js",
    "contributes":  {
                        "themes":  [
                                       {
                                           "label":  "One Dark Modern",
                                           "uiTheme":  "vs-dark",
                                           "path":  "./theme/onedark-modern.json"
                                       }
                                   ],
                        "iconThemes":  [
                                           {
                                               "id":  "office-lit-material-icon-theme",
                                               "label":  "Material Icon Theme (Office Viewer Lit)",
                                               "path":  "./theme/material-icons.json",
                                               "_watch":  true
                                           }
                                       ],
                        "languages":  [
                                          {
                                              "id":  "nginx",
                                              "aliases":  [
                                                              "NGINX Conf",
                                                              "NGINX",
                                                              "nginx"
                                                          ],
                                              "extensions":  [
                                                                 ".conf",
                                                                 ".conf.default",
                                                                 ".conf.template",
                                                                 "mime.types",
                                                                 "fastcgi_params",
                                                                 "scgi_params",
                                                                 "uwsgi_params",
                                                                 "nginx.conf",
                                                                 ".nginx"
                                                             ],
                                              "configuration":  "./syntaxes/nginx.configuration.json"
                                          },
                                          {
                                              "id":  "kotlin",
                                              "aliases":  [
                                                              "Kotlin"
                                                          ],
                                              "extensions":  [
                                                                 ".kt",
                                                                 ".kts"
                                                             ],
                                              "configuration":  "./syntaxes/kotlin-language-configuration.json"
                                          },
                                          {
                                              "id":  "toml",
                                              "aliases":  [
                                                              "TOML",
                                                              "Toml",
                                                              "toml"
                                                          ],
                                              "extensions":  [
                                                                 ".toml"
                                                             ],
                                              "configuration":  "./syntaxes/toml-language-configuration.json"
                                          },
                                          {
                                              "id":  "kusto",
                                              "aliases":  [
                                                              "Kusto",
                                                              "kusto",
                                                              "KQL",
                                                              "kql"
                                                          ],
                                              "extensions":  [
                                                                 ".csl",
                                                                 ".kusto",
                                                                 ".kql"
                                                             ],
                                              "configuration":  "./syntaxes/kusto-language-configuration.json"
                                          }
                                      ],
                        "grammars":  [
                                         {
                                             "language":  "nginx",
                                             "scopeName":  "source.nginx",
                                             "path":  "./syntaxes/nginx.tmLanguage",
                                             "embeddedLanguages":  {
                                                                       "meta.embedded.block.lua":  "lua"
                                                                   }
                                         },
                                         {
                                             "language":  "kotlin",
                                             "scopeName":  "source.kotlin",
                                             "path":  "./syntaxes/kotlin.tmLanguage.json"
                                         },
                                         {
                                             "language":  "toml",
                                             "scopeName":  "source.toml",
                                             "path":  "./syntaxes/toml.tmLanguage.json"
                                         },
                                         {
                                             "language":  "kusto",
                                             "scopeName":  "source.kusto",
                                             "path":  "./syntaxes/kusto.tmLanguage.json"
                                         }
                                     ],
                        "snippets":  [

                                     ],
                        "commands":  [
                                         {
                                             "command":  "office-lit.markdown.switch",
                                             "title":  "Switch markdown editor",
                                             "icon":  "$(edit)"
                                         },
                                         {
                                             "command":  "office-lit.csv.switch",
                                             "title":  "Switch CSV editor",
                                             "icon":  "$(edit)"
                                         },
                                         {
                                             "command":  "office-lit.markdown.paste",
                                             "title":  "Enhance paste in markdown",
                                             "enablement":  "!office-lit.extensionHost.web"
                                         }
                                     ],
                        "keybindings":  [
                                            {
                                                "command":  "office-lit.markdown.paste",
                                                "key":  "ctrl+v",
                                                "mac":  "cmd+v",
                                                "when":  "editorTextFocus \u0026\u0026 resourceLangId == markdown \u0026\u0026 !office-lit.extensionHost.web"
                                            },
                                            {
                                                "command":  "office-lit.markdown.switch",
                                                "key":  "ctrl+alt+e",
                                                "mac":  "ctrl+cmd+e",
                                                "when":  "editorTextFocus \u0026\u0026 editorLangId == markdown"
                                            }
                                        ],
                        "menus":  {
                                      "editor/title":  [
                                                           {
                                                               "command":  "office-lit.markdown.switch",
                                                               "when":  "resourceExtname == \u0027.md\u0027",
                                                               "group":  "navigation@-2"
                                                           },
                                                           {
                                                               "command":  "office-lit.csv.switch",
                                                               "when":  "resourceExtname == \u0027.csv\u0027 || resourceExtname == \u0027.tsv\u0027",
                                                               "group":  "navigation@-2"
                                                           }
                                                       ],
                                      "editor/context":  [

                                                         ]
                                  },
                        "customEditors":  [
                                              {
                                                  "viewType":  "mapleinori.officeViewerLit",
                                                  "displayName":  "CSV/TSV Viewer Lit",
                                                  "selector":  [
                                                                   {
                                                                       "filenamePattern":  "*.csv"
                                                                   },
                                                                   {
                                                                       "filenamePattern":  "*.tsv"
                                                                   }
                                                               ]
                                              },
                                              {
                                                  "viewType":  "mapleinori.markdownViewerLit",
                                                  "displayName":  "Markdown Editor Lit",
                                                  "selector":  [
                                                                   {
                                                                       "filenamePattern":  "file:/**/*.md"
                                                                   },
                                                                   {
                                                                       "filenamePattern":  "file:/**/*.markdown"
                                                                   },
                                                                   {
                                                                       "filenamePattern":  "vscode-vfs:/**/*.md"
                                                                   },
                                                                   {
                                                                       "filenamePattern":  "vscode-vfs:/**/*.markdown"
                                                                   },
                                                                   {
                                                                       "filenamePattern":  "vscode-remote:/**/*.md"
                                                                   },
                                                                   {
                                                                       "filenamePattern":  "vscode-remote:/**/*.markdown"
                                                                   }
                                                               ]
                                              }
                                          ],
                        "configuration":  [
                                              {
                                                  "title":  "Markdown",
                                                  "order":  1,
                                                  "properties":  {
                                                                     "vscode-office-lit.editorTheme":  {
                                                                                                           "type":  "string",
                                                                                                           "enum":  [
                                                                                                                        "Auto",
                                                                                                                        "Light",
                                                                                                                        "Solarized",
                                                                                                                        "Warm Light",
                                                                                                                        "Dim Light",
                                                                                                                        "One Dark",
                                                                                                                        "Github Dark",
                                                                                                                        "Nord",
                                                                                                                        "Monokai",
                                                                                                                        "Dracula"
                                                                                                                    ],
                                                                                                           "default":  "Auto",
                                                                                                           "markdownDescription":  "The theme for the Markdown editor."
                                                                                                       },
                                                                     "vscode-office-lit.codeMirrorTheme":  {
                                                                                                               "type":  "string",
                                                                                                               "enum":  [
                                                                                                                            "Auto",
                                                                                                                            "Github",
                                                                                                                            "Solarized Light",
                                                                                                                            "Material Light",
                                                                                                                            "Quiet Light",
                                                                                                                            "One Light",
                                                                                                                            "Dracula",
                                                                                                                            "Monokai",
                                                                                                                            "One Dark",
                                                                                                                            "Solarized Dark",
                                                                                                                            "Material Dark"
                                                                                                                        ],
                                                                                                               "default":  "Auto",
                                                                                                               "markdownDescription":  "CodeMirror syntax theme for code blocks in the Markdown editor."
                                                                                                           },
                                                                     "vscode-office-lit.mermaidTheme":  {
                                                                                                            "type":  "string",
                                                                                                            "enum":  [
                                                                                                                         "Auto",
                                                                                                                         "Light",
                                                                                                                         "Forest",
                                                                                                                         "Ocean",
                                                                                                                         "Sunset",
                                                                                                                         "Dark",
                                                                                                                         "Dracula",
                                                                                                                         "Monokai",
                                                                                                                         "Nord"
                                                                                                                     ],
                                                                                                            "default":  "Auto",
                                                                                                            "markdownDescription":  "Mermaid diagram theme in the Markdown editor. Auto follows the editor theme."
                                                                                                        },
                                                                     "vscode-office-lit.editMode":  {
                                                                                                        "type":  "string",
                                                                                                        "enum":  [
                                                                                                                     "wysiwyg",
                                                                                                                     "ir"
                                                                                                                 ],
                                                                                                        "default":  "wysiwyg",
                                                                                                        "markdownDescription":  "Default edit mode for the Markdown editor."
                                                                                                    },
                                                                     "vscode-office-lit.workspacePathAsImageBasePath":  {
                                                                                                                            "type":  "boolean",
                                                                                                                            "default":  false,
                                                                                                                            "description":  "Using workspace path as markdown image base path."
                                                                                                                        },
                                                                     "vscode-office-lit.pasterImgPath":  {
                                                                                                             "type":  "string",
                                                                                                             "default":  "image/${fileName}/${now}.${ext}",
                                                                                                             "description":  "Markdown paste image path, variables: workspaceDir, fileName, now, date (YYYYMMDD), uuid, ext (file extension)."
                                                                                                         }
                                                                 }
                                              },
                                              {
                                                  "title":  "Markdown PDF",
                                                  "order":  2,
                                                  "properties":  {
                                                                     "vscode-office-lit.chromiumPath":  {
                                                                                                            "type":  "string",
                                                                                                            "description":  "Set the chromium browser location for exporting markdown pdf."
                                                                                                        },
                                                                     "vscode-office-lit.puppeteerArgs":  {
                                                                                                             "type":  "array",
                                                                                                             "items":  {
                                                                                                                           "type":  "string"
                                                                                                                       },
                                                                                                             "default":  [

                                                                                                                         ],
                                                                                                             "description":  "Additional arguments to pass to Puppeteer/Chromium when exporting PDF. Example: [\"--no-sandbox\", \"--disable-setuid-sandbox\"] for Linux servers running as root."
                                                                                                         },
                                                                     "vscode-office-lit.pdfMarginTop":  {
                                                                                                            "type":  "integer",
                                                                                                            "default":  25,
                                                                                                            "description":  "Printed pdf default top margin."
                                                                                                        }
                                                                 }
                                              },
                                              {
                                                  "title":  "Telemetry",
                                                  "order":  99,
                                                  "properties":  {
                                                                     "vscode-office-lit.enableTelemetry":  {
                                                                                                               "type":  "boolean",
                                                                                                               "default":  false,
                                                                                                               "tags":  [
                                                                                                                            "telemetry",
                                                                                                                            "usesOnlineServices"
                                                                                                                        ],
                                                                                                               "markdownDescription":  "Enable anonymous usage data collection for Office Viewer Lit. This respects VS Code global telemetry settings (`#telemetry.telemetryLevel#`)."
                                                                                                           }
                                                                 }
                                              }
                                          ]
                    },
    "scripts":  {
                    "dev":  "vite --mode=development",
                    "dev:web":  "OFFICE_EXTENSION_TARGET=web vite --mode=development",
                    "lint:fix":  "eslint src/**/*.ts --fix",
                    "build":  "vite build --mode=production",
                    "package":  "vsce package --no-dependencies",
                    "publish":  "vsce publish --no-dependencies \u0026\u0026 ovsx publish --no-dependencies",
                    "vscode:prepublish":  "npm run build"
                },
    "devDependencies":  {
                            "@types/diff-match-patch":  "1.0.32",
                            "@types/node":  "^22.10.0",
                            "@types/react":  "^19.2.17",
                            "@types/react-dom":  "^19.2.3",
                            "@types/vscode":  "^1.64.0",
                            "@typescript-eslint/eslint-plugin":  "^7.1.1",
                            "@typescript-eslint/parser":  "^7.1.1",
                            "@vitejs/plugin-react":  "^6.0.2",
                            "chokidar":  "^5.0.0",
                            "esbuild":  "^0.28.1",
                            "esbuild-plugin-copy":  "2.1.1",
                            "eslint":  "^8.57.0",
                            "eslint-plugin-import":  "^2.29.1",
                            "eslint-plugin-react":  "^7.34.1",
                            "eslint-plugin-react-hooks":  "^7.1.1",
                            "eslint-plugin-react-refresh":  "^0.4.6",
                            "eslint-plugin-unused-imports":  "^3.1.0",
                            "less":  "^4.2.0",
                            "vite":  "^8.0.16",
                            "vite-plugin-static-copy":  "^4.1.1",
                            "@vscode/vsce":  "^3.7.0"
                        },
    "dependencies":  {
                         "@ant-design/icons":  "^5.3.5",
                         "@codemirror/commands":  "^6.10.3",
                         "@codemirror/lang-xml":  "^6.1.0",
                         "@codemirror/language":  "^6.12.3",
                         "@codemirror/language-data":  "^6.5.2",
                         "@codemirror/state":  "^6.6.0",
                         "@codemirror/view":  "^6.43.1",
                         "@lezer/highlight":  "^1.2.3",
                         "@vscode/codicons":  "^0.0.45",
                         "@vscode/extension-telemetry":  "^1.5.2",
                         "antd":  "^5.15.4",
                         "buffer":  "^6.0.3",
                         "chart.js":  "^4.5.1",
                         "cheerio":  "^1.0.0",
                         "chrome-finder":  "^1.0.7",
                         "codemirror":  "^6.0.2",
                         "codemirror-lang-latex":  "^0.4.1",
                         "codemirror-lang-mermaid":  "^0.5.0",
                         "date-format":  "^4.0.14",
                         "diff-match-patch":  "1.0.5",
                         "highlight.js":  "^11.10.0",
                         "iconv-lite":  "^0.6.3",
                         "katex":  "^0.16.2",
                         "markdown-it":  "^14.1.0",
                         "markdown-it-anchor":  "^9.2.0",
                         "markdown-it-checkbox":  "^1.1.0",
                         "markdown-it-toc-done-right":  "^4.2.0",
                         "mermaid":  "^11.15.0",
                         "mustache":  "^4.0.1",
                         "pdf-lib":  "^1.11.2",
                         "prosemirror-commands":  "^1.7.1",
                         "prosemirror-dropcursor":  "^1.8.2",
                         "prosemirror-history":  "^1.5.0",
                         "prosemirror-keymap":  "^1.2.3",
                         "prosemirror-model":  "^1.25.9",
                         "prosemirror-state":  "^1.4.4",
                         "prosemirror-tables":  "^1.8.5",
                         "prosemirror-transform":  "^1.12.0",
                         "prosemirror-view":  "^1.41.9",
                         "puppeteer-core":  "^25.1.0",
                         "react":  "^19.2.7",
                         "react-dom":  "^19.2.7",
                         "udsv":  "^0.5.3",
                         "vscode-html-to-docx":  "^1.1.2",
                         "yaml":  "^2.9.0",
                         "file-type":  "^21.0.0",
                         "save-svg-as-png":  "^1.4.17"
                     }
}